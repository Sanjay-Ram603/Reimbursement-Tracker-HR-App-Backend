        "type": "object",
        "properties": {
          "email": {
            "minLength": 1,
            "type": "string"
          },
          "password": {
            "minLength": 1,
            "type": "string"
          }
        },
        "additionalProperties": false
      },
      "PaymentMethodType": {
        "enum": [
          1,
          2,
          3
        ],
        "type": "integer",
        "format": "int32"
      },
      "ProcessPaymentRequestDto": {
        "type": "object",
        "properties": {
          "reimbursementRequestId": {
            "type": "string",
            "format": "uuid"
          },
          "amount": {
            "type": "number",
            "format": "double"
          },
          "paymentMethod": {
            "$ref": "#/components/schemas/PaymentMethodType"
          }
        },
        "additionalProperties": false
      },
      "RegisterUserRequestDto": {
        "required": [
          "email",
          "firstName",
          "lastName",
          "password",
          "roleId"
        ],
        "type": "object",
        "properties": {
          "firstName": {
            "minLength": 1,
            "type": "string"
          },
          "lastName": {
            "minLength": 1,
            "type": "string"
          },
          "email": {
            "minLength": 1,
            "type": "string"
          },
          "password": {
            "minLength": 1,
            "type": "string"
          },
          "roleId": {
            "type": "string",
            "format": "uuid"
          }
